
# --- Postgres ---
DB_USER=clouddrive
DB_PASSWORD=cambia_esta_password
DB_NAME=clouddrive
DB_PORT_HOST=5433        # puerto expuesto en el host (5433 para no chocar con otro Postgres)

# --- MinIO ---
MINIO_USER=minioadmin
MINIO_PASSWORD=cambia_esta_password
MINIO_BUCKET=archivos
MINIO_PORT_HOST=9000
MINIO_CONSOLE_HOST=9001

# --- API ---
API_PORT_HOST=3000
JWT_SECRET=genera_un_secreto_largo_y_aleatorio
# Origenes permitidos por CORS. "*" = cualquiera (comodo en dev; aceptable con
# auth por Bearer token). En produccion, fija el dominio del front:
# CORS_ORIGIN=https://tuapp.com  (o varios separados por coma)
CORS_ORIGIN=*

# --- Ollama ---
# En casa (con override): se ignora, la API usa http://ollama:11434
# En el servidor: la URL del Ollama que ya existe alli. Ver README.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:14b   # en maquinas pequenas: qwen2.5-coder:7b o qwen2.5:3b
OLLAMA_EMBED_MODEL=bge-m3        # 1024 dims; debe coincidir con la columna vector(1024)
# Cascada de visión para imágenes (ver extraccion.service.ts):
OLLAMA_CAPTION_MODEL=granite3.2-vision  # 1ª pasada: rápido, transcribe o describe
OLLAMA_OCR_MODEL=deepseek-ocr           # 2ª pasada: re-lee facturas para no fallar dígitos
                                        # (poner ambos al mismo modelo desactiva la 2ª pasada)

# --- Cola durable / worker (tareas.service.ts) ---
# Todas tienen valor por defecto; descomenta solo para ajustar.
# WORKER_CONCURRENCIA=1          # tareas en paralelo hacia Ollama (1 = no saturar la GPU)
# WORKER_POLL_MS=3000            # sondeo de respaldo (con despertar inmediato al encolar)
# WORKER_MAX_INTENTOS=3          # reintentos con backoff antes de marcar la tarea "error"

# --- Límites de uso (limites.middleware.ts) ---
# MAX_BACKLOG_USUARIO=200        # tope de tareas pendientes/en proceso por usuario (429 al superarlo)

# --- Mantenimiento periódico (reconciliacion.service.ts) ---
# MANTENIMIENTO_INTERVAL_HORAS=24  # reconciliación MinIO↔Postgres + retención
# RETENCION_PAPELERA_DIAS=0        # purga definitiva de la papelera tras N días (0 = desactivado)
